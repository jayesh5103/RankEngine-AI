# The port the Express server will listen on
PORT=3000

# The environment mode (development, production, test)
NODE_ENV=development

# MongoDB connection URI (local dev default shown below)
MONGODB_URI=mongodb://localhost:27017/rankengine

# Redis connection URL (local dev default shown below)
REDIS_URL=redis://localhost:6379

# JSON Web Token signing secret key (must be at least 8 characters)
JWT_SECRET=super_secret_jwt_sign_key_placeholder

# JWT expiration duration (e.g. 7d, 24h, 30m)
JWT_EXPIRY=7d
